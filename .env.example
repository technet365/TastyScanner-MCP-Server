# TastyScanner MCP Server Configuration
# Copy this to .env and fill in your credentials

# TastyTrade OAuth credentials (same as main TastyScanner app)
TASTY_CLIENT_ID=your_client_id
TASTY_CLIENT_SECRET=your_client_secret
TASTY_REFRESH_TOKEN=your_refresh_token
TASTY_ACCOUNT=              # optional — auto-detects first account if empty
TASTY_PRODUCTION=true       # true=production, false=sandbox/cert

# MCP Server
MCP_PORT=7698
LOG_LEVEL=info              # debug | info | warn | error
ENABLE_LIVE_TRADING=false   # SAFETY: set to true to allow execute_trade and adjust_order
MCP_AUTH_TOKEN=              # Bearer token for MCP endpoint auth. If set, all requests must include Authorization: Bearer <token>
